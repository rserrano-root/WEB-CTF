# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de données MySQL ─────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ctfuser
DB_PASSWORD=strongpassword
DB_NAME=ctfeur

# ── Session ───────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_64_char_random_hex
SESSION_NAME=nexus_sid
SESSION_MAX_AGE_MS=86400000

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
